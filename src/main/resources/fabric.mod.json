{
    "schemaVersion": 1,
    "id": "vanilla-outsider-bed-chat-hider",
    "version": "${version}",
    "name": "Vanilla Outsider: Bed Chat Hider",
    "description": "Adds a simple button to hide/show the chat box while sleeping.",
    "authors": [
        "DasikIgaijin"
    ],
    "contact": {
        "homepage": "https://github.com/Rifaditya",
        "sources": "https://github.com/Rifaditya/Vanilla-Outsider-Bed-Chat-Hider"
    },
    "license": "GPL-3.0",
    "icon": "assets/vanilla-outsider-bed-chat-hider/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "net.vanillaoutsider.bedchathider.BedChatHiderClient"
        ]
    },
    "mixins": [
        "vanilla-outsider-bed-chat-hider.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.16.9",
        "minecraft": ">=26.2-",
        "java": ">=25"
